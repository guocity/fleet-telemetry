{
  "host": "0.0.0.0",
  "port": 443,
  "log_level": "info",
  "json_log_enable": false,
  "namespace": "tesla_telemetry",
  "monitoring": {
    "prometheus_metrics_port": 9273,
    "profiler_port": 4269,
    "profiling_path": "/tmp/fleet-telemetry/profile",
    "statsd": {
      "host": "127.0.0.1:8125"
    }
  },
  "reliable_ack": false,
  "tls": {
    "server_cert": "./certs/fleet-telemetry-server/server.crt",
    "server_key": "./certs/fleet-telemetry-server/server.key"
  },
  "records": {
    "V": ["simple"],
    "alerts": ["simple"],
    "errors": ["simple"],
    "connectivity": ["simple"]
  },
  "transmit": {
    "simple": {
      "type": "simple",
      "config": {
        "base_path": "/data/telemetry",
        "verbose": true,
        "enable_delta": true,
        "snapshot_interval": 100,
        "delta_ttl": "24h"
      }
    }
  }
}
