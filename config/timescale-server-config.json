{
  "host": "0.0.0.0",
  "port": 8443,
  "log_level": "info",
  "json_log_enable": true,
  "namespace": "tesla",
  "reliable_ack": false,
  "monitoring": {
    "prometheus_metrics_port": 9090,
    "profiler_port": 0,
    "profiling_path": ""
  },
  "timescale": {
    "dsn": "postgresql://postgres:postgres@192.168.18.2:5432/fleet_telemetry",
    "batch_size": 500,
    "flush_interval_ms": 2000
  },
  "records": {
    "V": ["timescale"],
    "alerts": ["timescale"],
    "errors": ["timescale"],
    "connectivity": ["timescale"]
  },
  "tls": {
    "server_cert": "/certs/fleet-telemetry-server/server.crt",
    "server_key": "/certs/fleet-telemetry-server/server.key"
  }
}
